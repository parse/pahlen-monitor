#!/bin/sh

# Pre-commit hook: runs linting, formatting, and tests on backend
# Minimal output - shows progress, details all failures at end

TMPDIR_BASE=$(mktemp -d)
trap "rm -rf $TMPDIR_BASE" EXIT

FAILED=""

run_check() {
  local name="$1"
  local cmd="$2"
  local outfile="$TMPDIR_BASE/$name"

  printf "%s... " "$name"
  if eval "$cmd" > "$outfile" 2>&1; then
    echo "✓"
  else
    echo "✗"
    FAILED="${FAILED}${name}
"
  fi
}

run_check "Python: ruff" "ruff check custom_components backend"
run_check "Python: format" "ruff format --check custom_components backend"
run_check "Python: backend tests" "cd backend && PYTHONPATH=src DATABASE_URL=postgresql://user:pass@localhost/db PUSH_TOKEN=test-token python -m pytest tests"

if [ -n "$FAILED" ]; then
  echo ""
  printf "%s" "$FAILED" | while IFS= read -r name; do
    [ -z "$name" ] && continue

    echo "$name errors:"
    echo "----------------------------------------"
    cat "$TMPDIR_BASE/$name"
    echo "----------------------------------------"

    case "$name" in
      "Python: ruff") echo "Fix: Fix ruff issues" ;;
      "Python: format") echo "Fix: Fix ruff format issues" ;;
      "Python: backend tests") echo "Fix: Fix failing backend tests" ;;
    esac
    echo ""
  done
  exit 1
fi

exit 0
