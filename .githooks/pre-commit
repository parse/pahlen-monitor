#!/bin/sh

# Pre-commit hook: runs linting and format check on staged files
# Minimal output - shows progress, details all failures at end

TMPDIR_BASE=$(mktemp -d)
trap "rm -rf $TMPDIR_BASE" EXIT

FAILED=""

run_check() {
  local name="$1"
  local cmd="$2"
  local outfile="$TMPDIR_BASE/$name"

  printf "%s... " "$name"
  if eval "$cmd" > "$outfile" 2>&1; then
    echo "✓"
  else
    echo "✗"
    FAILED="${FAILED}${name}
"
  fi
}

run_check "Backend: TypeScript" "(cd backend && npm run typecheck)"
run_check "Backend: ESLint" "(cd backend && npm run lint)"
run_check "Backend: Prettier" "(cd backend && npm run format:check)"
run_check "Backend: Knip" "(cd backend && npm run knip)"
run_check "HomeAssistant HACS Plugin: ruff" "(cd custom_components && ruff check)"
run_check "HomeAssistant HACS Plugin: format" "(cd custom_components && ruff format --check)"

if [ -n "$FAILED" ]; then
  echo ""
  printf "%s" "$FAILED" | while IFS= read -r name; do
    [ -z "$name" ] && continue

    echo "$name errors:"
    echo "----------------------------------------"
    cat "$TMPDIR_BASE/$name"
    echo "----------------------------------------"

    case "$name" in
      "Backend: TypeScript") echo "Fix: Resolve type errors shown above" ;;
      "Backend: ESLint") echo "Fix: npm run lint:fix from backend folder" ;;
      "Backend: Prettier") echo "Fix: npm run format from backend folder" ;;
      "Backend: Knip") echo "Fix: Remove unused dependencies/exports shown above from backend folder" ;;
      "HomeAssistant HACS Plugin: ruff") echo "Fix: Fix ruff issues from custom_components folder" ;;
      "HomeAssistant HACS Plugin: format") echo "Fix: Fix ruff format issues from custom_components folder" ;;
    esac
    echo ""
  done
  exit 1
fi

exit 0
